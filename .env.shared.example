# 复制为 .env.shared 后填写（不要提交到仓库）

# --- Supabase / worker ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
BOM_LOCAL_ROOT=/absolute/path/to/bom_store

# --- 共享 Artifactory 凭据（worker + edge function 共用）---
IT_ARTIFACTORY_API_KEY=
IT_ARTIFACTORY_BASE_URL=https://it-artifactory.example.com
IT_ARTIFACTORY_EXT_API_KEY=
IT_ARTIFACTORY_EXT_BASE_URL=

# --- worker 可选 ---
IT_ARTIFACTORY_DOWNLOAD_TIMEOUT_MS=3600000
BOM_DOWNLOAD_STALE_SECONDS=900
BOM_DOWNLOAD_HEARTBEAT_MS=15000
BOM_DOWNLOAD_PROGRESS_FLUSH_MS=10000
