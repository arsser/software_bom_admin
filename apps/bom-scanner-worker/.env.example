# 复制为 .env；本机运行：npm run start:env（勿提交密钥）

# 本机 supabase：http://127.0.0.1:54321；
# 与 Kong 同网 Docker：http://kong:8000
SUPABASE_URL=xxx

# service_role JWT（控制台或 supabase status）
# 本地npm run start:env启动：需要设置。
# Docker部署：不用设置，由.deploy.env注入
SUPABASE_SERVICE_ROLE_KEY=xxx

# BOM 根目录绝对路径
# 本地npm run start:env启动：需要设置。
# Docker部署：不用设置，由.deploy.env注入
BOM_LOCAL_ROOT=xxx
