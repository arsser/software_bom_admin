# 复制为 .env 后填入（仓库根 .gitignore 已忽略 .env）
# 加载方式示例（bash）：
#   set -a && source .env && set +a && npm start
# 或 Node 20.6+：
#   node --env-file=.env src/index.mjs

# 必填：Supabase API（本地 CLI 默认 54321；与 Kong 同 Docker 网时用 http://kong:8000）
SUPABASE_URL=http://127.0.0.1:54321

# 必填：service_role（勿提交真实密钥）
SUPABASE_SERVICE_ROLE_KEY=

# 必填：本机要扫描的目录（绝对路径）
BOM_LOCAL_ROOT=

# 扫描间隔（秒）在 Web 系统设置 → BOM 本地扫描 中配置（写入 system_settings），勿在此文件设置

# --- it-Artifactory 自动下载（队列拉取）---
# 凭据统一从数据库 system_settings.artifactory_config 读取；此处无需配置 IT_ARTIFACTORY_*。
# 整段下载超时（毫秒，默认 3600000）
# IT_ARTIFACTORY_DOWNLOAD_TIMEOUT_MS=3600000
# （已废弃：仅队列拉取，不再使用后台 bom_rows_for_it_download 直通）
# 两次完整扫描周期间，每隔多少毫秒尝试抢占网页拉取队列（默认 3000）
# BOM_WORKER_IDLE_TICK_MS=3000

# --- 网页下载任务队列（bom_download_jobs）---
# 无心跳超过该秒数则标记失败（默认 900）
# BOM_DOWNLOAD_STALE_SECONDS=900
# 任务级心跳间隔（毫秒，默认 15000）
# BOM_DOWNLOAD_HEARTBEAT_MS=15000
# 字节进度写入 DB 的最小间隔（毫秒，默认 10000）
# BOM_DOWNLOAD_PROGRESS_FLUSH_MS=10000
