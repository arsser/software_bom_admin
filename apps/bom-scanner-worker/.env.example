# 复制为 .env 后填入（仓库根 .gitignore 已忽略 .env）
# 加载方式示例（bash）：
#   set -a && source .env && set +a && npm start
# 或 Node 20.6+：
#   node --env-file=.env src/index.mjs

# 必填：Supabase API（本地 CLI 默认 54321；与 Kong 同 Docker 网时用 http://kong:8000）
SUPABASE_URL=xxx

# 必填：service_role（勿提交真实密钥）
SUPABASE_SERVICE_ROLE_KEY=xxx

# 必填：本机要扫描的目录（绝对路径）
BOM_LOCAL_ROOT=xxx

# 拉取/上传心跳、队列轮询、僵死判定、单文件超时等已由 Web「系统设置 → BOM」中
# workerTuning（存 system_settings.bom_scanner）配置，不再使用本文件中的间隔类环境变量。
# ext 凭据仍可选用 IT_ARTIFACTORY_EXT_API_KEY / IT_ARTIFACTORY_EXT_BASE_URL 覆盖数据库配置。
