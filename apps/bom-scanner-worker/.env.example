# 复制为 .env 后填入（仓库根 .gitignore 已忽略 .env）
# 加载方式示例（bash）：
#   set -a && source .env && set +a && npm start
# 或 Node 20.6+：
#   node --env-file=.env src/index.mjs

# 必填：Supabase API（本地 CLI 默认 54321；与 Kong 同 Docker 网时用 http://kong:8000）
SUPABASE_URL=http://127.0.0.1:54321

# 必填：service_role（勿提交真实密钥）
SUPABASE_SERVICE_ROLE_KEY=

# 必填：本机要扫描的目录（绝对路径）
BOM_LOCAL_ROOT=

# 扫描间隔（秒）在 Web 系统设置 → BOM 本地扫描 中配置（写入 system_settings），勿在此文件设置
