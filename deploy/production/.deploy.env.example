# 生产环境配置示例
# 复制此文件为 .deploy.env 并填入实际值

# GitHub 仓库（用于拉取镜像），例如 your-org/your-repo
GITHUB_REPO=xxx

# Web 端口
WEB_PORT=80
WEB_SSL_PORT=443

# 数据库连接（用于迁移）
# 格式: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://postgres:your_password@supabase-db:5432/postgres?sslmode=disable

# 必填：Supabase 部署目录（用于 sync-edge-functions.sh / deploy.sh）
# 指向"自建 Supabase 的 docker-compose.yml 所在目录"（该目录下应存在 volumes/functions）
SUPABASE_DIR=xxx

# 必填：部署机「宿主机」可访问的 Supabase API 根地址
# 自建supabase常见为 8000 或通过 Nginx 反代，如：http://10.40.29.45/supabase
SUPABASE_URL=http://127.0.0.1:8000

# 必填：service_role JWT，注入 bom-scanner 容器（compose 无默认值，缺则 worker 无法连库）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# BOM 扫描 worker（docker-compose 中 bom-scanner 服务）
# 与 Supabase 同属 supabase_default 时，用 Kong 容器名访问 API（不要用 127.0.0.1）；未设置时 compose 默认 http://kong:8000
SUPABASE_URL_FOR_DOCKER=http://kong:8000
# 宿主机上 BOM 暂存目录，将挂载到容器内 BOM_LOCAL_ROOT
BOM_HOST_STORE=xxx
# 容器内扫描根路径（须与 volumes 挂载目标一致），尽量不要修改；
BOM_LOCAL_ROOT=/bom_store
