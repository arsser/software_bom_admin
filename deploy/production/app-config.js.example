// 生产环境运行时配置示例
// 复制为 app-config.js 并填入实际 Supabase 地址与 anon key。
// 部署时通过 volume 挂载到容器内 /usr/share/nginx/html/app-config.js
// 示例：
//   - 直接使用云端 Supabase：https://your-project.supabase.co
//   - 通过自建 Nginx 反代： http://10.40.29.45/supabase，不要用127.0.0.1，因为是在客户端的浏览器执行


window.__APP_CONFIG__ = {
    supabaseUrl: 'https://your-project.supabase.co',
    supabaseAnonKey: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...'
};
